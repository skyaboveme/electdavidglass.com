---
const year = new Date().getFullYear();

const links = [
  { text: 'About David', href: '/about' },
  { text: 'Results', href: '/results' },
  { text: 'Priorities', href: '/priorities' },
  { text: 'Precinct 4', href: '/precinct-4' },
  { text: 'Updates', href: '/updates' },
  { text: 'Contact', href: '/contact' },
];
---

<footer class="bg-navy text-white relative overflow-hidden">
  <!-- Decorative top border -->
  <div class="h-1 w-full bg-gradient-to-r from-red via-gold to-red"></div>
  
  <!-- Subtle pattern overlay -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>

  <div class="relative z-10 pt-16 pb-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
        
        <!-- Brand & Office Info -->
        <div class="space-y-4">
          <a href="/" class="flex items-center gap-3 group mb-6">
            <img src="/logo.png" alt="David Glass for Congress" class="h-16 w-auto drop-shadow-lg hover:scale-105 transition-transform duration-300" />
          </a>
          <p class="text-white/60 text-sm leading-relaxed">
            County Commissioner, Precinct 4<br/>
            Bastrop County, Texas
          </p>
          <div class="pt-2 space-y-1">
            <p class="text-white/50 text-sm">804 Pecan St, Bastrop, TX 78602</p>
            <a href="tel:+15125817100" class="text-gold hover:text-gold-light transition text-sm font-semibold">(512) 581-7100</a>
          </div>
        </div>

        <!-- Quick Links -->
        <div>
          <h3 class="font-sans font-bold text-sm uppercase tracking-widest text-gold mb-6">Quick Links</h3>
          <ul class="space-y-3">
            {links.map(link => (
              <li>
                <a href={link.href} class="text-white/60 hover:text-gold transition-colors flex items-center text-sm font-sans group">
                  <span class="text-gold/40 group-hover:text-gold mr-2 transition-colors">→</span> {link.text}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Email Signup -->
        <div>
          <h3 class="font-sans font-bold text-sm uppercase tracking-widest text-gold mb-6">Stay Connected</h3>
          <p class="text-white/50 mb-4 text-sm leading-relaxed">
            Get updates on Precinct 4 projects, county news, and community events.
          </p>
          <form class="space-y-3" id="footer-subscribe-form" action="/api/subscribe" method="POST">
            <div>
              <label for="footer-email" class="sr-only">Email address</label>
              <input 
                type="email" 
                id="footer-email" 
                name="email" 
                required
                class="w-full px-4 py-3 bg-white/5 text-white placeholder-white/30 border border-white/10 rounded-lg focus:ring-2 focus:ring-gold focus:border-gold outline-none transition text-sm"
                placeholder="Your email address"
              />
            </div>
            <button 
              type="submit" 
              class="w-full px-4 py-3 bg-gold text-white font-sans font-bold text-sm uppercase tracking-wider rounded-lg hover:bg-gold-light transition shadow-md"
            >
              Subscribe
            </button>
          </form>
        </div>

      </div>

      <!-- Bottom Bar -->
      <div class="border-t border-white/10 pt-8 mt-4">
        <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-center md:text-left">
          <div class="border border-gold/30 bg-gold/5 px-4 py-2 rounded-lg uppercase tracking-widest text-[11px] text-gold font-sans font-semibold">
            ★ Paid for by the David Glass Campaign ★
          </div>
          <div class="text-white/40 text-xs font-sans">
            &copy; {year} David Glass. All rights reserved.
            <span class="mx-2 hidden sm:inline">|</span>
            <a href="/privacy" class="hover:text-gold transition-colors inline-block mt-1 sm:mt-0">Privacy Policy</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
