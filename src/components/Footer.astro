---
const year = new Date().getFullYear();

const links = [
  { text: 'Home', href: '/' },
  { text: 'About', href: '/about' },
  { text: 'Results', href: '/results' },
  { text: 'Precinct 4', href: '/precinct-4' },
  { text: 'Priorities', href: '/priorities' },
  { text: 'Updates', href: '/updates' },
  { text: 'Contact', href: '/contact' },
];
---

<footer class="bg-navy text-white pt-16 pb-8 border-t-4 border-gold">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      
      <!-- Brand & Office Info -->
      <div class="space-y-4">
        <a href="/" class="text-3xl font-bold text-white flex flex-col uppercase tracking-wide leading-none mb-6">
          <span class="text-gold text-[1.2rem]">David</span>
          <span>Glass</span>
        </a>
        <p class="text-warm-gray">
          Bastrop County Commissioner, Precinct 4
        </p>
        <div class="pt-2">
          <h3 class="font-semibold text-white mb-2">Office</h3>
          <p class="text-warm-gray">804 Pecan St</p>
          <p class="text-warm-gray">Bastrop, TX 78602</p>
          <a href="/contact" class="inline-block mt-4 text-gold hover:text-white transition-colors underline decoration-gold underline-offset-4">
            Contact the office
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-semibold text-xl mb-6 text-white border-b border-white/20 pb-2 inline-block">Quick Links</h3>
        <ul class="space-y-3">
          {links.map(link => (
            <li>
              <a href={link.href} class="text-warm-gray hover:text-gold transition-colors flex items-center">
                <span class="text-gold mr-2 text-sm">&#9656;</span> {link.text}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Compact Email Signup -->
      <div>
        <h3 class="font-semibold text-xl mb-6 text-white border-b border-white/20 pb-2 inline-block">Stay Connected</h3>
        <p class="text-warm-gray mb-4 text-sm leading-relaxed">
          Get updates on Precinct 4 projects, county news, and community events directly to your inbox.
        </p>
        <form class="space-y-3" id="footer-subscribe-form" action="/api/subscribe" method="POST">
          <div>
            <label for="footer-email" class="sr-only">Email address</label>
            <input 
              type="email" 
              id="footer-email" 
              name="email" 
              required
              class="w-full px-4 py-3 bg-white/10 text-white placeholder-white/50 border border-white/20 rounded focus:ring-2 focus:ring-gold focus:border-gold outline-none transition"
              placeholder="Your email address"
            />
          </div>
          <button 
            type="submit" 
            class="w-full px-4 py-3 bg-gold text-white font-bold rounded hover:bg-gold/90 transition shadow-sm"
          >
            Sign Up
          </button>
        </form>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-white/20 pt-8 mt-4 flex flex-col md:flex-row justify-between items-center text-sm text-warm-gray gap-4 text-center md:text-left">
      <div class="border border-white/30 px-4 py-2 uppercase tracking-wide text-xs">
        Paid for by the David Glass Campaign
      </div>
      <div>
        &copy; {year} David Glass. All rights reserved.
        <span class="mx-2 hidden sm:inline">|</span>
        <a href="/privacy" class="hover:text-gold transition-colors block sm:inline mt-2 sm:mt-0">Privacy Policy</a>
      </div>
    </div>
  </div>
</footer>
