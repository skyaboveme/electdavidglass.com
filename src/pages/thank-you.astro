---
import Base from '../layouts/Base.astro';
---

<Base title="Thank You" description="Thank you for reaching out to David Glass.">
  <section class="page-header-gradient pt-28 pb-20 relative min-h-[60vh] flex items-center justify-center">
    <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-gold/20 text-gold mb-8 shadow-lg border border-gold/30">
        <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-serif font-extrabold text-white leading-tight mb-6">
        Message Received
      </h1>
      <p class="text-xl font-sans font-light text-white/80 leading-relaxed mb-10 max-w-xl mx-auto">
        Thank you for reaching out. We appreciate your engagement with Precinct 4 and will be in touch shortly.
      </p>
      <a href="/" class="inline-flex items-center px-8 py-4 text-sm font-sans font-bold uppercase tracking-wider rounded-lg bg-gold text-white hover:bg-white hover:text-navy transition-all shadow-lg">
        Return to Homepage
      </a>
    </div>
  </section>
</Base>
