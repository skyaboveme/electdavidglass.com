---
import Base from '../layouts/Base.astro';
---

<Base title="Precinct 4" description="Discover what David Glass is working on in Precinct 4, including Elgin and eastern Bastrop County.">
  
  <!-- Page Header -->
  <section class="page-header-gradient pt-28 pb-20 relative">
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="gold-line mx-auto mb-6"></div>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-serif font-extrabold text-white mb-6">Precinct 4 Operations</h1>
      <p class="text-xl font-sans font-light text-white/70 leading-relaxed max-w-2xl mx-auto">
        Serving Elgin, the surrounding rural communities, and the eastern stretches of Bastrop County.
      </p>
    </div>
  </section>

  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Map & Communities -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start mb-24">
        
        <!-- Map -->
        <div class="lg:col-span-7 reveal-left">
          <div class="relative bg-cream rounded-2xl p-6 shadow-lg border border-warm-gray">
            <img 
              src="/pricinctaBastrop county.jpeg" 
              alt="Map of Bastrop County showing Precinct 4 highlighted in blue" 
              class="w-full h-auto rounded-xl"
            />
            <div class="absolute top-4 right-4 bg-navy text-white px-3 py-1.5 rounded-lg text-xs font-sans font-bold uppercase tracking-wider shadow-md">
              Precinct 4
            </div>
          </div>
        </div>

        <!-- Communities Content -->
        <div class="lg:col-span-5 reveal-right">
          <div class="gold-line mb-6"></div>
          <h2 class="text-3xl font-serif font-bold text-navy mb-6">Communities Served</h2>
          <p class="text-near-black/70 leading-relaxed mb-8 font-sans">
            Precinct 4 encompasses the vibrant, historic city of Elgin, rapid-growth corridors, and the deep rural heritage of eastern Bastrop County. This diversity requires a commissioner who understands both urban development and rural land management.
          </p>
          
          <div class="space-y-5">
            <div class="bg-cream rounded-xl p-5 border border-warm-gray hover-lift">
              <h3 class="text-lg font-serif font-bold text-navy mb-1">Elgin & Surrounds</h3>
              <p class="text-near-black/70 text-sm font-sans">Managing unprecedented growth while partnering with the Elgin EDC to ensure development benefits residents.</p>
            </div>
            <div class="bg-cream rounded-xl p-5 border border-warm-gray hover-lift">
              <h3 class="text-lg font-serif font-bold text-navy mb-1">Rural Corridors</h3>
              <p class="text-near-black/70 text-sm font-sans">Prioritizing safety and maintenance on county roads heavily traveled by agricultural, residential, and commercial traffic.</p>
            </div>
            <div class="bg-cream rounded-xl p-5 border border-warm-gray hover-lift">
              <h3 class="text-lg font-serif font-bold text-navy mb-1">Eastern Bastrop</h3>
              <p class="text-near-black/70 text-sm font-sans">Protecting the fundamental rural character of Bastrop County from unchecked sprawl.</p>
            </div>
          </div>
        </div>

      </div>

      <!-- Active Projects -->
      <div class="mb-24 reveal">
        <div class="mb-10 text-center">
          <div class="gold-line mx-auto mb-6"></div>
          <h2 class="text-3xl sm:text-4xl font-serif font-bold text-navy mb-4">Active Projects</h2>
          <p class="text-lg text-near-black/70 max-w-2xl mx-auto font-sans">Transparency on road repairs, infrastructure improvements, and planning efforts.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 reveal-stagger">
          <!-- Project 1 -->
          <div class="bg-cream rounded-2xl p-6 border border-warm-gray hover-lift">
            <div class="flex justify-between items-start mb-4">
              <h3 class="text-lg font-serif font-bold text-navy">Precinct 4 Road Resurfacing Initiative</h3>
              <span class="bg-navy text-white text-xs font-sans font-bold px-3 py-1 rounded-full uppercase tracking-wider flex-shrink-0 ml-3">In Progress</span>
            </div>
            <p class="text-near-black/70 text-sm font-sans leading-relaxed">Executing the approved multi-phase mill and overlay plan across heavily prioritized corridors to extend road lifespan.</p>
          </div>
          <!-- Project 2 -->
          <div class="bg-cream rounded-2xl p-6 border border-warm-gray hover-lift">
            <div class="flex justify-between items-start mb-4">
              <h3 class="text-lg font-serif font-bold text-navy">Drainage Clearances — Southeast Corridors</h3>
              <span class="bg-gold text-white text-xs font-sans font-bold px-3 py-1 rounded-full uppercase tracking-wider flex-shrink-0 ml-3">Planning</span>
            </div>
            <p class="text-near-black/70 text-sm font-sans leading-relaxed">Evaluating right-of-way boundaries and allocating equipment for major drainage overhauls ahead of storm season.</p>
          </div>
        </div>
      </div>

      <!-- Report a Concern -->
      <div class="page-header-gradient rounded-2xl p-8 sm:p-12 text-center reveal">
        <div class="relative z-10">
          <h2 class="text-3xl font-serif font-bold text-white mb-4">Report a Concern</h2>
          <p class="text-lg text-white/60 leading-relaxed max-w-2xl mx-auto mb-8 font-sans">
            See a pothole, drainage issue, or missing sign on a county road in Precinct 4? Our crews cannot fix what they do not know about.
          </p>
          <a href="/contact" class="inline-flex justify-center items-center px-8 py-3 text-sm font-sans font-bold uppercase tracking-wider rounded-lg bg-gold text-white hover:bg-gold-light transition shadow-md">
            Submit an Issue
          </a>
        </div>
      </div>

    </div>
  </section>

</Base>
