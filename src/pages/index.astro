---
import Base from '../layouts/Base.astro';

// Placeholder image (will be replaced later)
const heroImage = "/IMG_4833.jpeg"; 
---

<Base title="Home" description="David Glass - Proven Leadership for Bastrop County Commissioner Precinct 4">
  
  <!-- Hero Section -->
  <section class="relative w-full h-[85vh] min-h-[600px] flex items-center bg-navy overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0 z-0">
      <img 
        src={heroImage} 
        alt="Bastrop County landscape" 
        class="w-full h-full object-cover opacity-60 mix-blend-overlay"
        loading="eager"
      />
      <!-- Gradient overlay for text legibility -->
      <div class="absolute inset-0 bg-gradient-to-r from-navy/95 via-navy/80 to-transparent"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full pt-20">
      <div class="max-w-3xl">
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-white leading-tight tracking-tight mb-6">
          David Glass <span class="text-gold block sm:inline mt-2 sm:mt-0">.</span> Proven Leadership for Bastrop County
        </h1>
        <p class="text-xl sm:text-2xl text-warm-gray mb-10 max-w-2xl font-light leading-relaxed">
          Protecting roads, managing growth, and keeping taxes responsible.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#get-updates" class="inline-flex justify-center items-center px-8 py-4 text-lg font-bold rounded bg-gold text-white hover:bg-gold/90 hover:-translate-y-0.5 transition shadow-lg w-full sm:w-auto text-center">
            Get Updates
          </a>
          <a href="/contact" class="inline-flex justify-center items-center px-8 py-4 text-lg font-bold rounded bg-transparent border-2 border-white text-white hover:bg-white/10 transition w-full sm:w-auto text-center">
            Contact David
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Authority Snapshot -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
        <div class="lg:col-span-5 prose prose-lg prose-navy">
          <h2 class="text-3xl sm:text-4xl font-bold mb-6 text-navy">Built in Bastrop County. Built for Bastrop County.</h2>
          <p class="text-xl leading-relaxed text-near-black mb-6">
            David Glass has spent his life building in Bastrop County. As a business owner, rancher, and community leader for more than four decades, he understands what it takes to manage growth without losing what makes this place home. That is why he serves as your County Commissioner.
          </p>
          <a href="/about" class="inline-flex items-center text-gold font-bold hover:text-navy transition-colors text-lg group">
            Meet David Glass <span class="ml-2 group-hover:translate-x-1 transition-transform">&rarr;</span>
          </a>
        </div>
        
        <div class="lg:col-span-7">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
            <!-- Proof Point 1 -->
            <div class="bg-warm-gray/30 p-8 rounded border-l-4 border-gold">
              <h3 class="text-xl font-bold text-navy mb-3">Lifelong Bastrop County Resident</h3>
              <p class="text-near-black">Raised here. Built here. Stayed here.</p>
            </div>
            <!-- Proof Point 2 -->
            <div class="bg-warm-gray/30 p-8 rounded border-l-4 border-gold">
              <h3 class="text-xl font-bold text-navy mb-3">40+ Year Business Owner</h3>
              <p class="text-near-black">Founded and ran a national software company. Understands budgets, operations, and accountability.</p>
            </div>
            <!-- Proof Point 3 -->
            <div class="bg-warm-gray/30 p-8 rounded border-l-4 border-gold">
              <h3 class="text-xl font-bold text-navy mb-3">Infrastructure & Water Expertise</h3>
              <p class="text-near-black">President of Aqua Water Supply Corporation. Knows the systems that keep communities running.</p>
            </div>
            <!-- Proof Point 4 -->
            <div class="bg-warm-gray/30 p-8 rounded border-l-4 border-gold">
              <h3 class="text-xl font-bold text-navy mb-3">Family Roots</h3>
              <p class="text-near-black">Married 40+ years. 4 children. 6 grandchildren. His stake in this county is personal.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Results Preview -->
  <section class="py-24 bg-navy text-white bg-[url('/pattern-subtle.svg')] bg-repeat">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4 text-white">Results That Matter</h2>
        <p class="text-xl text-warm-gray font-light max-w-2xl mx-auto">Not just talk. Measurable outcomes that protect our quality of life and respect your tax dollars.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        <!-- Stat Card 1 -->
        <div class="bg-white/5 border border-white/20 p-8 rounded backdrop-blur-sm text-center transform transition duration-300 hover:-translate-y-1 hover:border-gold">
          <div class="text-4xl font-extrabold text-gold mb-4">Dozens</div>
          <h3 class="text-xl font-bold mb-2">Road Projects</h3>
          <p class="text-warm-gray leading-relaxed text-sm">Completed across Precinct 4 to keep our communities connected and safe.</p>
        </div>
        <!-- Stat Card 2 -->
        <div class="bg-white/5 border border-white/20 p-8 rounded backdrop-blur-sm text-center transform transition duration-300 hover:-translate-y-1 hover:border-gold">
          <div class="text-4xl font-extrabold text-gold mb-4">Steady</div>
          <h3 class="text-xl font-bold mb-2">Tax Strategy</h3>
          <p class="text-warm-gray leading-relaxed text-sm">Consistent budgetary restraint to ensure core services without ballooning county debt.</p>
        </div>
        <!-- Stat Card 3 -->
        <div class="bg-white/5 border border-white/20 p-8 rounded backdrop-blur-sm text-center transform transition duration-300 hover:-translate-y-1 hover:border-gold">
          <div class="text-4xl font-extrabold text-gold mb-4">Managed</div>
          <h3 class="text-xl font-bold mb-2">Growth & Water</h3>
          <p class="text-warm-gray leading-relaxed text-sm">Balancing inevitable development with the infrastructure and water resources required to support it.</p>
        </div>
      </div>
      
      <div class="text-center">
        <a href="/results" class="inline-flex items-center text-gold font-bold hover:text-white transition-colors text-lg group">
          See Full Results <span class="ml-2 group-hover:translate-x-1 transition-transform">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Precinct 4 Spotlight -->
  <section class="py-24 bg-warm-gray/30 border-y border-warm-gray">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- Text Content -->
        <div>
          <h2 class="text-3xl sm:text-4xl font-bold mb-6 text-navy">Your Precinct. Your Home.</h2>
          <p class="text-xl leading-relaxed text-near-black mb-8">
            Precinct 4 covers the vital northern and eastern stretches of Bastrop County, including Elgin and our extensive rural communities. David Glass is working directly with families, landowners, and local businesses here to ensure our area isn't left behind or paved over.
          </p>
          <ul class="space-y-4 mb-8">
            <li class="flex items-start">
              <span class="text-gold mr-3 mt-1 text-xl">&#9656;</span>
              <span class="text-near-black font-semibold">Active road maintenance schedules</span>
            </li>
            <li class="flex items-start">
              <span class="text-gold mr-3 mt-1 text-xl">&#9656;</span>
              <span class="text-near-black font-semibold">Community-driven infrastructure improvements</span>
            </li>
            <li class="flex items-start">
              <span class="text-gold mr-3 mt-1 text-xl">&#9656;</span>
              <span class="text-near-black font-semibold">Protecting our rural character</span>
            </li>
          </ul>
          <a href="/precinct-4" class="inline-flex px-6 py-3 border-2 border-navy text-navy font-bold rounded hover:bg-navy hover:text-white transition-colors">
            Explore Precinct 4 Projects
          </a>
        </div>
        
        <!-- Map/Image Placeholder -->
        <div class="relative bg-white p-4 shadow-sm rounded border border-warm-gray aspect-video flex items-center justify-center">
          <div class="text-center text-near-black/60">
            <svg class="h-16 w-16 mx-auto mb-4 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
            </svg>
            <p class="font-semibold">[Map of Precinct 4 goes here]</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Priorities Preview -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold mb-16 text-navy">Core Priorities</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div class="text-left">
          <div class="w-16 h-16 bg-navy/5 rounded flex items-center justify-center mb-6 border border-navy/10">
            <svg class="w-8 h-8 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-navy mb-4">Roads & Infrastructure</h3>
          <p class="text-near-black leading-relaxed">Maintaining and upgrading the arteries that connect our communities as Bastrop County grows.</p>
        </div>
        
        <div class="text-left">
          <div class="w-16 h-16 bg-gold/10 rounded flex items-center justify-center mb-6 border border-gold/20">
            <svg class="w-8 h-8 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-navy mb-4">Responsible Growth</h3>
          <p class="text-near-black leading-relaxed">Managing development deliberately so it serves existing residents, rather than letting it happen to us.</p>
        </div>
        
        <div class="text-left">
          <div class="w-16 h-16 bg-navy/5 rounded flex items-center justify-center mb-6 border border-navy/10">
            <svg class="w-8 h-8 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-navy mb-4">Fiscal Accountability</h3>
          <p class="text-near-black leading-relaxed">Treating every tax dollar carefully and transparently. Budgets should be tight and tied to real outcomes.</p>
        </div>
      </div>
      
      <div class="mt-16">
        <a href="/priorities" class="inline-flex items-center text-navy font-bold hover:text-gold transition-colors text-lg group">
          Read More on Priorities <span class="ml-2 group-hover:translate-x-1 transition-transform">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Final CTA / Email Signup -->
  <section id="get-updates" class="py-24 bg-navy relative border-t-4 border-gold">
    <div class="absolute inset-0 bg-gradient-to-br from-navy to-navy/80 z-0"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-5xl font-extrabold text-white mb-6">Stay Connected</h2>
      <p class="text-xl text-warm-gray mb-10 max-w-2xl mx-auto font-light leading-relaxed">
        Get updates on Precinct 4 projects, county news, and community events. No spam. Just the information that matters to you.
      </p>
      
      <form class="max-w-md mx-auto space-y-4 text-left" action="/api/subscribe" method="POST">
        <div>
          <label for="first-name" class="block text-sm font-medium text-warm-gray mb-1">First Name</label>
          <input 
            type="text" 
            id="first-name" 
            name="firstName" 
            required 
            class="w-full px-4 py-3 bg-white text-near-black rounded focus:ring-4 focus:ring-gold/30 focus:border-gold outline-none transition shadow-sm"
            placeholder="Jane"
          />
        </div>
        <div class="pb-2">
          <label for="email-address" class="block text-sm font-medium text-warm-gray mb-1">Email Address</label>
          <input 
            type="email" 
            id="email-address" 
            name="email" 
            required 
            class="w-full px-4 py-3 bg-white text-near-black rounded focus:ring-4 focus:ring-gold/30 focus:border-gold outline-none transition shadow-sm"
            placeholder="jane@example.com"
          />
        </div>
        <button 
          type="submit" 
          class="w-full px-6 py-4 text-lg font-bold rounded bg-gold text-white hover:bg-gold/90 transition shadow-lg mt-2 flex justify-center items-center"
        >
          Sign Me Up
        </button>
      </form>
    </div>
  </section>

</Base>
