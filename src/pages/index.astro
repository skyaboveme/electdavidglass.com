---
import Base from '../layouts/Base.astro';
---

<Base title="Home" description="David Glass — Proven leadership for Bastrop County Commissioner Precinct 4. Roads, fiscal accountability, water security, and managed growth.">
  
  <!-- ============================================
       HERO SECTION — Cinematic Full-Viewport
       ============================================ -->
  <section class="relative w-full min-h-[100vh] flex items-center bg-navy overflow-hidden pt-24">
    <!-- Gradient background -->
    <div class="absolute inset-0 bg-gradient-to-br from-navy via-navy-light to-navy z-0"></div>
    
    <!-- Subtle pattern -->
    <div class="absolute inset-0 z-[1] opacity-[0.04]" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>

    <!-- Portrait (right side on desktop) -->
    <div class="absolute right-0 bottom-0 top-0 w-[55%] hidden lg:block z-[2]">
      <div class="absolute inset-0 bg-gradient-to-r from-navy via-navy/70 to-transparent z-10"></div>
      <img 
        src="/DG.jpeg" 
        alt="David Glass, Bastrop County Commissioner" 
        class="w-full h-full object-cover object-top"
        loading="eager"
      />
    </div>

    <!-- Content -->
    <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-20 lg:py-0">
      <div class="max-w-2xl">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-gold/15 border border-gold/30 rounded-full mb-8">
          <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
          <span class="text-gold font-sans font-semibold text-sm uppercase tracking-widest">Bastrop County Commissioner · Precinct 4</span>
        </div>

        <!-- Headline -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-serif font-extrabold text-white leading-[1.1] tracking-tight mb-6">
          Proven Leadership.
          <span class="block gradient-text mt-2">Real Results.</span>
        </h1>

        <!-- Subheadline -->
        <p class="text-xl sm:text-2xl text-white/70 mb-10 max-w-xl font-sans font-light leading-relaxed">
          Protecting our roads, managing growth responsibly, and keeping your tax dollars accountable.
        </p>
        
        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#get-involved" class="inline-flex justify-center items-center px-8 py-4 text-lg font-sans font-bold uppercase tracking-wider rounded-lg bg-gold text-white hover:bg-gold-light hover:-translate-y-0.5 transition-all shadow-xl w-full sm:w-auto text-center">
            Get Involved
          </a>
          <a href="/results" class="inline-flex justify-center items-center px-8 py-4 text-lg font-sans font-bold uppercase tracking-wider rounded-lg bg-transparent border-2 border-white/30 text-white hover:bg-white/10 hover:border-white/50 transition-all w-full sm:w-auto text-center">
            See My Record
          </a>
        </div>
      </div>
    </div>

    <!-- Mobile portrait (below content) -->
    <div class="lg:hidden absolute bottom-0 right-0 w-40 h-40 sm:w-52 sm:h-52 z-[2] overflow-hidden opacity-30">
      <div class="absolute inset-0 bg-gradient-to-tr from-navy via-transparent to-transparent z-10"></div>
      <img 
        src="/DG.jpeg" 
        alt="" 
        class="w-full h-full object-cover object-top rounded-tl-3xl"
        aria-hidden="true"
      />
    </div>
  </section>

  <!-- ============================================
       AUTHORITY STRIP — Social Proof Bar
       ============================================ -->
  <section class="bg-cream border-y border-warm-gray relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 text-center reveal-stagger">
        <div class="py-2">
          <div class="counter-number text-3xl sm:text-4xl text-navy mb-1" data-count="40" data-suffix="+">0+</div>
          <p class="text-slate text-sm font-sans font-medium uppercase tracking-wide">Years in Business</p>
        </div>
        <div class="py-2">
          <div class="counter-number text-3xl sm:text-4xl text-navy mb-1">President</div>
          <p class="text-slate text-sm font-sans font-medium uppercase tracking-wide">Aqua Water Supply</p>
        </div>
        <div class="py-2">
          <div class="counter-number text-3xl sm:text-4xl text-navy mb-1" data-count="6">0</div>
          <p class="text-slate text-sm font-sans font-medium uppercase tracking-wide">Grandchildren</p>
        </div>
        <div class="py-2">
          <div class="counter-number text-3xl sm:text-4xl text-navy mb-1">Lifelong</div>
          <p class="text-slate text-sm font-sans font-medium uppercase tracking-wide">Bastrop Resident</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       MEET DAVID — Split Section
       ============================================ -->
  <section class="py-20 sm:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        
        <!-- Photo -->
        <div class="reveal-left">
          <div class="relative">
            <div class="absolute -top-4 -left-4 w-full h-full border-2 border-gold/30 rounded-2xl"></div>
            <img 
              src="/davidglass2.jpeg" 
              alt="David Glass in the community" 
              class="relative z-10 w-full rounded-2xl shadow-2xl object-cover aspect-[4/5]"
            />
            <!-- Floating badge -->
            <div class="absolute -bottom-4 -right-4 z-20 bg-navy text-white px-5 py-3 rounded-xl shadow-lg">
              <p class="font-serif font-bold text-lg">40+ Years</p>
              <p class="text-gold text-sm font-sans">Serving Bastrop County</p>
            </div>
          </div>
        </div>

        <!-- Bio Content -->
        <div class="reveal-right">
          <div class="gold-line mb-6"></div>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-serif font-bold text-navy mb-6 leading-tight">
            Built in Bastrop County.<br/>Built for Bastrop County.
          </h2>
          <p class="text-xl text-near-black leading-relaxed mb-6 font-sans">
            David Glass has spent his life building in Bastrop County. As a business owner, rancher, and community leader for more than four decades, he understands what it takes to manage growth without losing what makes this place home.
          </p>
          <p class="text-near-black/70 leading-relaxed mb-8 font-sans">
            Before entering public service, David built and ran a successful national software company. He brought that same operational rigor — tight budgets, real accountability, measurable outcomes — directly to Bastrop County government.
          </p>
          <a href="/about" class="inline-flex items-center text-gold font-sans font-bold hover:text-navy transition-colors text-lg group uppercase tracking-wide">
            Read David's Full Story <span class="ml-2 group-hover:translate-x-2 transition-transform">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       THREE PILLARS — Priority Cards
       ============================================ -->
  <section class="py-20 sm:py-28 bg-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <div class="gold-line mx-auto mb-6"></div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-serif font-bold text-navy mb-4">Core Priorities</h2>
        <p class="text-xl text-slate font-sans font-light max-w-2xl mx-auto">
          Focused on the issues that directly impact your family and your property.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 reveal-stagger">
        <!-- Pillar 1 -->
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-warm-gray hover-lift group">
          <div class="w-14 h-14 bg-navy/5 rounded-xl flex items-center justify-center mb-6 group-hover:bg-navy/10 transition-colors">
            <svg class="w-7 h-7 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-2xl font-serif font-bold text-navy mb-3">Roads & Infrastructure</h3>
          <p class="text-near-black/70 leading-relaxed mb-6 font-sans">
            Maintaining and upgrading the arteries that connect our communities as Bastrop County grows at record pace.
          </p>
          <a href="/priorities" class="text-gold font-sans font-bold text-sm uppercase tracking-wide group-hover:text-navy transition-colors">
            Learn More →
          </a>
        </div>
        
        <!-- Pillar 2 -->
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-warm-gray hover-lift group">
          <div class="w-14 h-14 bg-gold/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-gold/15 transition-colors">
            <svg class="w-7 h-7 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-2xl font-serif font-bold text-navy mb-3">Fiscal Accountability</h3>
          <p class="text-near-black/70 leading-relaxed mb-6 font-sans">
            Treating every tax dollar carefully and transparently. Budgets should be tight and tied to measurable outcomes.
          </p>
          <a href="/priorities" class="text-gold font-sans font-bold text-sm uppercase tracking-wide group-hover:text-navy transition-colors">
            Learn More →
          </a>
        </div>
        
        <!-- Pillar 3 -->
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-warm-gray hover-lift group">
          <div class="w-14 h-14 bg-navy/5 rounded-xl flex items-center justify-center mb-6 group-hover:bg-navy/10 transition-colors">
            <svg class="w-7 h-7 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-2xl font-serif font-bold text-navy mb-3">Water & Growth</h3>
          <p class="text-near-black/70 leading-relaxed mb-6 font-sans">
            Balancing development with the infrastructure and water resources required to support the communities we already have.
          </p>
          <a href="/priorities" class="text-gold font-sans font-bold text-sm uppercase tracking-wide group-hover:text-navy transition-colors">
            Learn More →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       RESULTS PROOF — Dark Impact Section
       ============================================ -->
  <section class="py-20 sm:py-28 page-header-gradient text-white relative">
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <div class="gold-line mx-auto mb-6"></div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-serif font-bold text-white mb-4">Results That Matter</h2>
        <p class="text-xl text-white/60 font-sans font-light max-w-2xl mx-auto">Not just talk. Measurable outcomes that protect our quality of life.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16 reveal-stagger">
        <!-- Stat 1 -->
        <div class="glass-card p-8 text-center hover-lift">
          <div class="counter-number text-5xl text-gold mb-3">Dozens</div>
          <h3 class="text-xl font-serif font-bold text-white mb-2">Road Projects</h3>
          <p class="text-white/50 text-sm font-sans leading-relaxed">Completed across Precinct 4 to keep communities connected and safe.</p>
        </div>
        <!-- Stat 2 -->
        <div class="glass-card p-8 text-center hover-lift">
          <div class="counter-number text-5xl text-gold mb-3">Steady</div>
          <h3 class="text-xl font-serif font-bold text-white mb-2">Tax Strategy</h3>
          <p class="text-white/50 text-sm font-sans leading-relaxed">Consistent budgetary restraint to deliver core services without tax hikes.</p>
        </div>
        <!-- Stat 3 -->
        <div class="glass-card p-8 text-center hover-lift">
          <div class="counter-number text-5xl text-gold mb-3">Managed</div>
          <h3 class="text-xl font-serif font-bold text-white mb-2">Growth & Water</h3>
          <p class="text-white/50 text-sm font-sans leading-relaxed">Balancing development with the resources required to sustain it.</p>
        </div>
      </div>

      <!-- Quote Block -->
      <div class="max-w-3xl mx-auto text-center reveal">
        <blockquote class="relative">
          <svg class="w-10 h-10 text-gold/30 mx-auto mb-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H0z"/>
          </svg>
          <p class="text-xl sm:text-2xl font-serif italic text-white/80 leading-relaxed mb-6">
            "I will continue to bring business sense, transparency, and hard work to the Commissioner's Court. Bastrop County is our home, and I intend to keep it a place we are all proud of."
          </p>
          <cite class="text-gold font-sans font-semibold uppercase tracking-widest text-sm not-italic">— David Glass</cite>
        </blockquote>
      </div>
      
      <div class="text-center mt-12 reveal">
        <a href="/results" class="inline-flex items-center text-gold font-sans font-bold hover:text-white transition-colors text-lg group uppercase tracking-wide">
          See Full Record <span class="ml-2 group-hover:translate-x-2 transition-transform">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================
       PRECINCT 4 SPOTLIGHT — With Real Map
       ============================================ -->
  <section class="py-20 sm:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Map -->
        <div class="reveal-left order-2 lg:order-1">
          <div class="relative bg-cream rounded-2xl p-6 shadow-lg border border-warm-gray">
            <img 
              src="/pricinctaBastrop county.jpeg" 
              alt="Map of Bastrop County showing Precinct 4 boundaries" 
              class="w-full h-auto rounded-xl"
            />
            <div class="absolute top-4 right-4 bg-navy text-white px-3 py-1.5 rounded-lg text-xs font-sans font-bold uppercase tracking-wider shadow-md">
              Precinct 4
            </div>
          </div>
        </div>

        <!-- Content -->
        <div class="reveal-right order-1 lg:order-2">
          <div class="gold-line mb-6"></div>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-serif font-bold text-navy mb-6 leading-tight">
            Your Precinct.<br/>Your Home.
          </h2>
          <p class="text-xl text-near-black leading-relaxed mb-6 font-sans">
            Precinct 4 covers the vital northern and eastern stretches of Bastrop County, including Elgin and our extensive rural communities.
          </p>
          <ul class="space-y-4 mb-8">
            <li class="flex items-start">
              <span class="text-gold mr-3 mt-1 text-lg">★</span>
              <span class="text-near-black font-sans font-semibold">Active road maintenance schedules</span>
            </li>
            <li class="flex items-start">
              <span class="text-gold mr-3 mt-1 text-lg">★</span>
              <span class="text-near-black font-sans font-semibold">Community-driven infrastructure improvements</span>
            </li>
            <li class="flex items-start">
              <span class="text-gold mr-3 mt-1 text-lg">★</span>
              <span class="text-near-black font-sans font-semibold">Protecting our rural character</span>
            </li>
          </ul>
          <a href="/precinct-4" class="inline-flex items-center px-6 py-3 border-2 border-navy text-navy font-sans font-bold text-sm uppercase tracking-wider rounded-lg hover:bg-navy hover:text-white transition-all">
            Explore Precinct 4 Projects
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       GET INVOLVED — CTA & Email Signup
       ============================================ -->
  <section id="get-involved" class="py-20 sm:py-28 bg-cream relative">
    <!-- Decorative gold line at top -->
    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-transparent via-gold to-transparent"></div>
    
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="reveal">
        <div class="gold-line mx-auto mb-6"></div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-serif font-extrabold text-navy mb-6">Stay Connected</h2>
        <p class="text-xl text-slate mb-10 max-w-2xl mx-auto font-sans font-light leading-relaxed">
          Get updates on Precinct 4 projects, county news, and community events. No spam. Just the information that matters to you.
        </p>
      </div>
      
      <form class="max-w-md mx-auto space-y-4 text-left reveal" action="/api/subscribe" method="POST">
        <div>
          <label for="first-name" class="block text-sm font-sans font-semibold text-near-black mb-1.5 uppercase tracking-wide">First Name</label>
          <input 
            type="text" 
            id="first-name" 
            name="firstName" 
            required 
            class="w-full px-4 py-3.5 bg-white text-near-black border border-warm-gray rounded-lg focus:ring-2 focus:ring-gold focus:border-gold outline-none transition shadow-sm font-sans"
            placeholder="Jane"
          />
        </div>
        <div class="pb-2">
          <label for="email-address" class="block text-sm font-sans font-semibold text-near-black mb-1.5 uppercase tracking-wide">Email Address</label>
          <input 
            type="email" 
            id="email-address" 
            name="email" 
            required 
            class="w-full px-4 py-3.5 bg-white text-near-black border border-warm-gray rounded-lg focus:ring-2 focus:ring-gold focus:border-gold outline-none transition shadow-sm font-sans"
            placeholder="jane@example.com"
          />
        </div>
        <button 
          type="submit" 
          class="w-full px-6 py-4 text-lg font-sans font-bold uppercase tracking-wider rounded-lg bg-gold text-white hover:bg-navy transition-all shadow-lg mt-2 flex justify-center items-center"
        >
          Sign Me Up
        </button>
      </form>

      <div class="mt-12 flex flex-col sm:flex-row justify-center gap-4 reveal">
        <a href="/contact" class="inline-flex justify-center items-center px-6 py-3 border-2 border-navy text-navy font-sans font-bold text-sm uppercase tracking-wider rounded-lg hover:bg-navy hover:text-white transition-all">
          Contact David
        </a>
      </div>
    </div>
  </section>

</Base>
